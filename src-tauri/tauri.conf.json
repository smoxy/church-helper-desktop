{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "church-helper-desktop",
  "version": "0.2.0",
  "identifier": "com.smoxy.church-helper-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "church-helper-desktop",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' https: data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyNjMwNzRFMzhCRDBBMTIKUldRU0NyMDRUZ2Rqd3NVaktqV2IzdndsVlFlZjQ4elhkVDV4SnBYbURrTEk0NzJKeUNOQXN2Wk4K",
      "endpoints": [
        "https://github.com/smoxy/church-helper-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
